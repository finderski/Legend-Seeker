mixin attribute(attr)
    - const [shortName, longName] = attr;
    - const fieldName = `attr_${longName}`;
    - const translationLabel = `${longName}-abbr`;
    - const lastPart = longName.slice(3);
    
      div(class=divLabel)
        .attribute-field
            button(class="labelButton", type="roll", name=`roll_${longName}_check`, value=`&{template:default} {{name=@{character_name}}} {{title=^{${labelKey}}}} {{Roll=[[1d120]]}}`)
                span(class="allcaps", data-i18n=translationLabel) #{shortName}
                span(class="smallcaps", data-i18n=`${longName}-minus-first-three`) #{lastPart}
        .score-field
            input(class="attributeInput", type="text", name=fieldName, placeholder="3")
        .modifier-field
            input(class="attributeInput readOnly", type="text", name=`attr_${shortName}_modifier`, placeholder="0", readonly)