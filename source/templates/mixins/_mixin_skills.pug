mixin skills(skill)
    // ['skill name', 'attribute', 'na|some|trained', 'yes|no']
    - const [skillName, attributeName, training, armorCheck] = skill;
    - const fieldName = `attr_${skillName}`;
    - const capitalizeWords = str => str.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    - const capitalizedSkillName = capitalizeWords(skillName);
    - const fullAbilityList = ['strength', 'dexterity', 'constitution', 'intelligence', 'wisdom', 'charisma'];
    - const isManaTap = skillName === 'mana-tap';

        if isManaTap
            input(class="hideSection", type="hidden", name=`attr_${skillName}_hider`, value="0")
        .skill
            .skillName
                if training === 'trained' 
                    input(class="trainedHidden", type="hidden", name=`attr_${skillName}_trained`, value="0")
                .chatButtons
                    // button(class="sendToChat labelButton", type="roll", name=`roll_${skillName}_check`, value=`@{${skillName}_formula}`, data-i18n-title="roll-skill-check")
                    button(class=["sendToChat", "labelButton", { smaller: skillName === 'lore-dungeoneering' }], type="roll", name=`roll_${skillName}_check`, value=`@{${skillName}_formula}`, data-i18n-title="roll-skill-check")
                        if training === 'trained'
                            span
                                img.icon(src='https://raw.githubusercontent.com/finderski/Legend-Seeker/main/images/Training_Required.png', data-i18n-alt="trained-skill")
                                | 
                        else if training === 'some'
                            span
                                | 
                                img.icon(src='https://raw.githubusercontent.com/finderski/Legend-Seeker/main/images/Some_Training_Required.png', data-i18n-alt="some-training-required")
                        span(class="allcaps", data-i18n=skillName) 
                            | #{capitalizedSkillName}
                        if armorCheck === 'yes'
                            span
                                | 
                                img.icon(src='https://raw.githubusercontent.com/finderski/Legend-Seeker/main/images/Armor_Check_Icon.png', data-i18n-alt="armor-check-penalty-applies")
                    .whisperButton 
                        button(class="whisperToChat", type="roll", name="roll_whisper_edge", value=`/w gm @{${skillName}_formula}`)
                            span.iconButton w
                    if armorCheck === 'yes'
                        input(type='hidden', name=`attr_${skillName}_formula`, value=`&{template:roll} {{name=@{character_name}}} {{title=^{${skillName}}}} {{roll=[[1d20 + @{armor_check_penalty}[Armor Check Penalty] + @{multi-action-penalty}[Multi-Action Penalty] + @{${skillName}_bonus}[${capitalizedSkillName}} Bonus]+@{condition}+?{Additional Modifiers|0}[modifier-pop-up]]]}}`)
                    else
                        input(type='hidden', name=`attr_${skillName}_formula`, value=`&{template:roll} {{name=@{character_name}}} {{title=^{${skillName}}}}} {{roll=[[1d20 + @{multi-action-penalty}[Multi-Action Penalty] + @{${skillName}_bonus}[${capitalizedSkillName}} Bonus]+@{condition}+?{Additional Modifiers|0}[modifier-pop-up]]]}}`)
            .skillDetails
            .skillBonus 
                input(class="attributeInput readOnly", type="text", name=`attr_${skillName}_bonus` readonly)
            .equals
            .halfLevel
                span(class="attributeInput readOnly", type="text", name=`attr_half-level`)
            .addition
            //-
            .abilityMod 
                // If statement used to be here...
                input(class="showAttMod showWatermark", type='hidden', name=`attr_${skillName}_ability`, value=`@{${attributeName}}`)
                span(class="attributeInput strength readOnly", type="text", name="attr_strength_modifier")
                span(class="attributeInput dexterity readOnly", type="text", name="attr_dexterity_modifier")
                span(class="attributeInput constitution readOnly", type="text", name="attr_constitution_modifier")
                span(class="attributeInput intelligence readOnly", type="text", name="attr_intelligence_modifier")
                span(class="attributeInput wisdom readOnly", type="text", name="attr_wisdom_modifier")
                span(class="attributeInput charisma readOnly", type="text", name="attr_charisma_modifier")
                each ability in fullAbilityList
                    span(class=`abilityWatermark ${ability}`, data-i18n=`${ability}-abbr`) #{ability.slice(0,3).toUpperCase()}
                if skillName === 'mana-tap'
                    .config 
                        label.cog
                            input(class='hiddenInput', type='checkbox', name=`attr_${skillName}_config_toggle`, value="1")
                            span.configIcon y
                //-
                    else
                        span(class="attributeInput readOnly", type="text", name=`attr_${attributeName}_modifier`)
                        input(class="showWatermark", type='hidden', name=`attr_${skillName}_ability`, value=`@{${attributeName}}`)
                        each ability in fullAbilityList
                            span(class=`abilityWatermark ${ability}`, data-i18n=`${ability}-abbr`) #{ability.slice(0,3).toUpperCase()}
            if attributeName === "dexterity"
                input(class="cappedDexMod", type="hidden", name="attr_dex_is_capped", value="0")
                .cappedMod 
                    img(src='https://raw.githubusercontent.com/finderski/Legend-Seeker/main/images/armor_worn.png', data-i18n-alt="capped-dex-mod")
            .addition
            .trained
                label
                    input(class="hiddenInput", type="checkbox", name=`attr_${skillName}_trained`, value="5")
                    span.trained 5
                    span.untrained 0
            .addition
            .skillFocus
                // input(class="attributeInput", type="text", name=`attr_${skillName}_focus`, value="0")
                label
                    input(class="hiddenInput", type="checkbox", name=`attr_${skillName}_focus`, value="3")
                    span.trained 3
                    span.untrained 0
            .addition
            .miscMod
                input(class="attributeInput", type="text", name=`attr_${skillName}_misc`, value="0")
        input(class=`skillConfig`, type="hidden", name=`attr_${skillName}_config_toggle`)
        div(class=`skillConfigSection`)
            .spacer &nbsp;
            .abilityModSelector
                label(class="fieldLabelAbove", data-i18n='linked-attribute') Linked Attribute
                select(class="ls-Dropdown", name=`attr_${skillName}_ability`)
                    if attributeName === 'strength'
                        option(value="@{strength}", selected=(attributeName === 'strength'), data-i18n='strength') Strength
                    if attributeName === 'dexterity'
                        option(value="@{dexterity}", selected=(attributeName === 'dexterity'), data-i18n='dexterity') Dexterity
                    if attributeName === 'constitution'
                        option(value="@{constitution}", selected=(attributeName === 'constitution'), data-i18n='constitution') Constitution
                    if attributeName === 'intelligence' || isManaTap
                        option(value="@{intelligence}", selected=(attributeName === 'intelligence'), data-i18n='intelligence') Intelligence
                    if attributeName === 'wisdom' || isManaTap
                        option(value="@{wisdom}", selected=(attributeName === 'wisdom'), data-i18n='wisdom') Wisdom
                    if attributeName === 'charisma' || isManaTap
                        option(value="@{charisma}", selected=(attributeName === 'charisma'), data-i18n='charisma') Charisma
            .endSpacer &nbsp;
