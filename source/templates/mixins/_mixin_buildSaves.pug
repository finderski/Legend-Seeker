mixin savingthrow(save)
    - const [shortName, longName, attributeName] = save;
    - const fieldName = `attr_${longName}`;
    - const translationLabel = `${longName}-abbr`;
    - const lastPart = longName.slice(3);
    
      .saveRow
        .saveButton
            button(class="labelButton", type="roll", name=`roll_${longName}_check`, value=`&{template:default} {{name=@{character_name}}} {{title=^{${longName}}}} {{Roll=[[1d20 + @{${shortName}_modifier}[Attribute Modifier]]]}}`)
                span(class="allcaps", data-i18n=translationLabel) #{shortName}
                span(class="smallcaps", data-i18n=`${longName}-minus-first-three`) #{lastPart}
        .saveTotal
            input(class="attributeInput", type="text", name=fieldName, placeholder="3")
        .saveCalc
            input(class="attributeInput readOnly", type="text", name=`${fieldName}_modifier`, placeholder="0", readonly)
        .saveLvlOrArmor
            input(class="attributeInput", type="text", name=`${fieldName}_lvlOrArmor`, placeholder="0")
        .saveClassBonus
            input(class="attributeInput", type="text", name=`${fieldName}_classBonus`, placeholder="0")
        .saveAbilityMod
            input(class="attributeInput", type="text", name=`${fieldName}_abilityMod`, placeholder="0")
        .saveMisc
            input(class="attributeInput", type="text", name=`${fieldName}_misc`, placeholder="0")