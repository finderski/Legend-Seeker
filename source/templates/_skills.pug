    const skillList = [['acrobatics','dexterity','some','yes'],['climb', 'strength','na','yes'],['craft', 'wisdom','na','no'],['deception', 'charisma','some','no'],  ['endurance', 'constitution','na','yes'],['gather-information','charisma','na','no'],['initiative','dexterity','na','yes'],['invoke-arcana','intelligence','trained','no'],['jump','strength','na','yes'],['lore','intelligence','na','no'],['notice','wisdom','na','yes'],['persuasion','charisma','na','no'],['ride','dexterity','na','yes'],['sense-motive','wisdom','na','no'],['stealth','dexterity','na','yes'],['survival','wisdom','na','no'],['swim','strength','na','yes'],['tinkering','intelligence','trained','yes'],['treat-wounds','wisdom','some','no'],['mana-tap','charisma','trained','no']];
