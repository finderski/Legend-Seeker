// Necessary Mixins
include ./mixins/_mixin_attributes.pug 
include ./mixins/_mixin_corruption.pug
include ./mixins/_mixin_buildSaves.pug
include ./mixins/_mixin_skills.pug

.maindiv
    //h1(class='sheetTitle', data-i18n='character-score-sheet') Character Score Sheet
    // Hidden inputs for character sheet functionality
    // Tab Styling in _tabSetup.scss
    // buttonbar styles in the _buttonbarStyles.scss
    input(type='hidden', class='selectedTab', name='attr_sheetTab', value="1")
    .buttonbar 
        // Buttons to control the sheet display
        include _buttonbar.pug
    .frontPage
        h1(class='sheetTitle', data-i18n='character-score-sheet') Character Score Sheet
        .topSection
            .demographics 
                // Character Sheet (including NPC sheet)
                include _demographics.pug
            .logo 
                // Logo Section
                img(src='https://raw.githubusercontent.com/finderski/Legend-Seeker/main/images/lengend-seeker-logo.png', alt='Legend Seeker Logo')
        hr.sectionDivider
        .middleSection 
            .twoByOne 
                .firstCol
                    .threeBythree
                        .attributesSection
                            // Attributes Section
                            include _attributes.pug
                        .stamina 
                            // Staminia Section
                            include _stamina.pug
                        .hitPoints 
                            // Hit Point Section
                            include _hitPoints.pug
                        .corruption
                            // Corruption Section
                            include _corruption.pug
                        .defensiveSaves
                            //Defensive Saves Section
                            include _saves.pug
                .secondCol
                    h3.headerLabel(data-i18n="conditions") CONDITIONS
                    // Conditions Section
                    include _conditions.pug
                    include _languages.pug
        .damageReduction 
            // Damage Reduction Section
            input(type='hidden', name='attr_total_dr', value="0")
            span(data-i18n='total-damage-reduction-abbr') Total DR: 
            span(name="attr_total_dr")
        hr.sectionDivider
        .combat
            input(class="hideSection", type="hidden", name="attr_mana-tap_hider", value="0")
            .spells 
                include _spells.pug
            .weapons 
                include _weapons.pug
    .backPage
        .topContainer
            .equipment 
                include _equipment.pug
                hr.sectionDivider
                include _armor.pug
                include _classResources.pug
            .skills 
                include _skills.pug
        hr.sectionDivider
        .bottomSection
            // Talents Section
            .talents 
                include _talents.pug
            // Edges Section
            .edges 
                include _edges.pug
            //Special Traits Section
            .traits 
                include _specialTraits.pug
    .concise 
        h1.headerLabel(data-i18n="concise") Concise
        include _concise.pug
    .sheetSettings
        h1.headerLabel(data-i18n="settings") Settings
        include _settings.pug

